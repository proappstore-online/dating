{
  "name": "dating",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": { "node": ">=22" },
  "repository": { "type": "git", "url": "git+https://github.com/proappstore-online/dating.git" },
  "scripts": {
    "dev": "pnpm --filter @dating/web dev",
    "build": "pnpm --filter @dating/web build",
    "preview": "pnpm --filter @dating/web preview",
    "typecheck": "pnpm --filter @dating/web exec tsc -b",
    "test": "pnpm --filter @dating/web test",
    "test:watch": "pnpm --filter @dating/web test:watch",
    "test:coverage": "pnpm --filter @dating/web test:coverage"
  }
}
